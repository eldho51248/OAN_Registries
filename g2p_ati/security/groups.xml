<?xml version="1.0" encoding="utf-8" ?>
<odoo>


    <record id="group_data_enumerator" model="res.groups">
        <field name="name">Data Enumerator</field>
         <field name="category_id" ref="g2p_registry_base.openg2p_module" />

    </record>

    <record id="group_data_collector" model="res.groups">
        <field name="name">Data Collector</field>
         <field name="category_id" ref="g2p_registry_base.openg2p_module" />
            <field name="implied_ids" eval="[(4, ref('group_data_enumerator'))]" />
    </record>

    <record id="group_data_collection_supervisor" model="res.groups">
        <field name="name">Data Collectoion Supervisor</field>
            <field name="implied_ids" eval="[(4, ref('group_data_collector'))]" />
         <field name="category_id" ref="g2p_registry_base.openg2p_module" />
    </record>




    <record id="group_data_validator" model="res.groups">
        <field name="name">Data Validator</field>
         <field name="category_id" ref="g2p_registry_base.openg2p_module" />
    </record>


    <record id="group_data_admin" model="res.groups">
        <field name="name">Data Admin</field>
         <field name="category_id" ref="g2p_registry_base.openg2p_module" />

    </record>

    <record id="group_system_admin" model="res.groups">
        <field name="name">System Admin</field>
             <field name="category_id" ref="g2p_registry_base.openg2p_module" />
    </record>


     <record id="g2p_registry_base.group_g2p_admin" model="res.groups">
            <field name="name">Super Admin</field>
        </record>


</odoo>
