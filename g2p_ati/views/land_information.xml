<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_individuals_form_land_information_inherited" model="ir.ui.view">
        <field name="name">view_individuals_form_land_information</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_individual.view_individuals_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='relationships']" position="after">
                <page string="Land Information" name="lands">
                    <field name="land_information_ids">
                        <tree editable="bottom">
                            <field name="total_land_area" />
                            <field name="ownership_type" />
                            <field name="land_certificate" />
                        </tree>
                    </field>
                </page>
                <page string="Crop Information" name="crops">
                    <field name="crop_information_ids">
                        <tree editable="bottom">
                            <field name="crop" />
                            <field name="illness_type" widget="many2many_tags" />
                        </tree>
                    </field>
                </page>
                <page string="Livestock Information" name="livestocks">
                    <field name="livestock_information_ids">
                        <tree editable="bottom">
                            <field name="livestock_type" />
                            <field name="livestock_bred" />
                            <field name="number_of_livestock" />
                            <field name="illness_type" widget="many2many_tags" />
                            <field name="illness_images" widget="many2many_binary" />
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>


