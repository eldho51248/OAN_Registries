<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_crop_category_tree" model="ir.ui.view">
        <field name="name">view_crop_category_tree</field>
        <field name="model">g2p.crop.category</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree editable="top">
            	<field name="name" />
            </tree>
        </field>
    </record>

  <record id="view_crop_tree" model="ir.ui.view">
        <field name="name">view_crop_tree</field>
        <field name="model">g2p.crop</field>
        <field name="priority">1</field>
        <field name="arch" type="xml">
            <tree>
				<field name="name" />
            	<field name="category" />
            </tree>
        </field>
    </record>

	<record id="view_crop_form" model="ir.ui.view">
		<field name="name">view_crop_form</field>
		<field name="model">g2p.crop</field>
		<field name="arch" type="xml">
			<form>
                <sheet>
                    <group>
		   	            <field name="category" />
				        <field name="name" />
                    </group>
                </sheet>
				<div class="oe_chatter">
					<field name="message_follower_ids" widget="mail_followers" />
					<field name="activity_ids" widget="mail_activity" />
					<field name="message_ids" widget="mail_thread" />
				</div>
			</form>
		</field>
	</record>

	<record id="g2p_crop_category_tree_action" model="ir.actions.act_window">
		<field name="name">Crop category</field>
		<field name="res_model">g2p.crop.category</field>
		<field name="view_mode">tree</field>
	</record>

	<record id="g2p_crop_variety_tree_action" model="ir.actions.act_window">
		<field name="name">Crop Variety</field>
		<field name="res_model">g2p.crop.variety</field>
		<field name="view_mode">tree,form</field>
	</record>


	<record id="g2p_crop_view_tree_action" model="ir.actions.act_window">
		<field name="name">Crops</field>
		<field name="res_model">g2p.crop</field>
		<field name="view_mode">tree,form,graph</field>
	</record>

	<menuitem
        id="g2p_crop_variety_menu"
        action="g2p_crop_variety_tree_action"
        name="Crop Varieties"
        sequence="630"
        groups="g2p_registry_base.group_g2p_admin,g2p_registry_base.group_g2p_registrar"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />


	<menuitem
        id="g2p_crop_category_menu"
        action="g2p_crop_category_tree_action"
        name="Crop Category"
        sequence="620"
        groups="g2p_registry_base.group_g2p_admin,g2p_registry_base.group_g2p_registrar"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />


	<menuitem
        id="g2p_crop_menu"
        action="g2p_crop_view_tree_action"
        name="Crops"
        sequence="610"
        groups="g2p_registry_base.group_g2p_admin,g2p_registry_base.group_g2p_registrar"
        parent="g2p_registry_base.g2p_configuration_menu_root"
    />

</odoo>
