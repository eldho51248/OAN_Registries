				<header>
					<button
                        name="state_approve"
                        invisible="state!='draft'"
                        string="Approve"
                        type="object"
                        class="btn-success"
                        groups="g2p_ati.group_data_validator,g2p_registry_base.group_g2p_admin,g2p_registry_base.group_g2p_registrar"
                    />
					<button
                        name="state_reject"
