<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <data>

        <!-- Tree View -->
        <record id="view_crop_registry_tree" model="ir.ui.view">
            <field name="name">g2p.crop.registry.tree</field>
            <field name="model">g2p.crop.registry</field>
            <field name="arch" type="xml">
                <tree string="Crop Sown Registry">
                    <field name="zone_name_id"/>
                    <field name="land_id"/>
                    <field name="land_area"/>
                    <field name="owner_name"/>
                </tree>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_g2p_crop_registry_form" model="ir.ui.view">
            <field name="name">g2p.crop.registry.form</field>
            <field name="model">g2p.crop.registry</field>
            <field name="arch" type="xml">
                <form string="Crop Sown Registry">
                    <sheet>
                        <group>
                            <group>
                                <!--                                <field name="farmer_id"-->
                                <!--                                       context="{'show_farmer_id': True}"-->
                                <!--                                       options="{'no_create': True}"/>-->
                                <field name="farmer_display_id"/>
                                <field name="zone_name_id"/>
                                <field name="woreda_name_id"/>
                                <field name="kebele_name"/>
                                <field name="kebele_code"/>
                                <field name="land_id"/>
                                <field name="land_area"/>
                                <field name="owner_name"/>
                                <field name="ownership_type"/>
                                <field name="land_certificate"/>
                                <field name="soil_fertility"/>
                                <field name="current_land_use"/>
                                <field name="crop_name_id"/>
                                <field name="crop_variety_id"/>
                                <field name="crop_area"/>
                                <field name="crop_season_id"/>
                                <field name="crop_produce_min"/>
                                <field name="crop_produce_max"/>
                                <field name="crop_wholesale_min"/>
                                <field name="crop_wholesale_max"/>
                                <field name="crop_retail_min"/>
                                <field name="crop_retail_max"/>
                                <field name="crop_volume"/>
                                <field name="live_stock_type_id"/>
                                <field name="live_stock_number"/>
                            </group>
                            <group>
                                <field name="live_stock_water_source"/>
                                <field name="cultivation_land"/>
                                <field name="cultivation_area"/>
                                <field name="cultivation_crop_name_id"/>
                                <field name="sown_land"/>
                                <field name="sown_area"/>
                                <field name="sown_crop_name_id"/>
                                <field name="harvested_land"/>
                                <field name="harvested_area"/>
                                <field name="harvested_crop_name_id"/>
                                <field name="irrigation_type"/>
                                <field name="surveyor_name"/>
                                <field name="surveyor_fullname"/>
                                <field name="surveyor_mobile_number"/>
                                <field name="supervisor_name"/>
                                <field name="supervisor_fullname"/>
                                <field name="supervisor_mobile_number"/>
                                <field name="first_approvel_status"/>
                                <field name="second_approvel_status"/>
                                <field name="verifier_name"/>
                                <field name="verifier_mobile_number"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Basic Info">
                                <group>
                                    <field name="region_name_id"/>
                                    <field name="land_plan"/>
                                    <field name="production_plan"/>
                                    <field name="productivity"/>
                                    <field name="gps"/>
                                </group>
                            </page>
                            <page string="Land Details">
                                <group>
                                    <field name="total_cultivated_land"/>
                                    <field name="cultivated_land_by_tractor"/>
                                    <field name="total_sown_land"/>
                                    <field name="sown_land_by_tractor"/>
                                </group>
                            </page>
                            <page string="Farmers">
                                <group>
                                    <field name="male_farmers"/>
                                    <field name="female_farmers"/>
                                    <field name="total_farmers"/>
                                </group>
                            </page>
                            <page string="Cluster Information">
                                <group>
                                    <field name="cluster_plan"/>
                                    <field name="cluster_collected_land"/>
                                    <field name="cluster_collected_quintal"/>
                                    <field name="cluster_participant_farmers"/>
                                </group>
                            </page>
                            <page string="Harvest and Production">
                                <group>
                                    <field name="collected_land"/>
                                    <field name="collected_land_quintal"/>
                                    <field name="collected_by_combiner"/>
                                    <field name="production_in_quintal"/>
                                    <field name="total_plan"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_g2p_crop_registry_search" model="ir.ui.view">
            <field name="name">g2p.crop.registry.search</field>
            <field name="model">g2p.crop.registry</field>
            <field name="arch" type="xml">
                <search string="Search Crop Sown Registry">

                    <!-- Search Fields -->
                    <field name="farmer_display_id"/>
                    <field name="zone_name_id"/>
                    <field name="woreda_name_id"/>
                    <field name="kebele_name"/>
                    <field name="land_id"/>
                    <field name="owner_name"/>
                    <field name="crop_name_id"/>
                    <field name="crop_season_id"/>

                    <!-- Filters -->
                    <filter string="Approved Level 1"
                            name="first_approved"
                            domain="[('first_approvel_status', '=', True)]"/>

                    <filter string="Approved Level 2"
                            name="second_approved"
                            domain="[('second_approvel_status', '=', True)]"/>

                    <!-- Group By -->
                    <group expand="0" string="Group By">

                        <filter string="Zone"
                                name="group_by_zone"
                                context="{'group_by':'zone_name_id'}"/>

                        <filter string="Woreda"
                                name="group_by_woreda"
                                context="{'group_by':'woreda_name_id'}"/>

                        <filter string="Crop"
                                name="group_by_crop"
                                context="{'group_by':'crop_name_id'}"/>

                        <filter string="Season"
                                name="group_by_season"
                                context="{'group_by':'crop_season_id'}"/>

                    </group>

                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_g2p_crop_registry" model="ir.actions.act_window">
            <field name="name">Crop Sown Registry</field>
            <field name="res_model">g2p.crop.registry</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_g2p_crop_registry_search"/>
        </record>

        <!-- Menu -->
        <menuitem id="g2p_crop_registry_menu_item_id"
                  name="Crop Sown Registry"
        />

        <menuitem
                id="menu_gn_division"
                name="Crop Sown Registry"
                parent="g2p_crop_registry_menu_item_id"
                action="action_g2p_crop_registry"
                sequence="6"
        />

    </data>

</odoo>
