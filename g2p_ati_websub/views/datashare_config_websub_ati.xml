<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- This module extends the WebSub functionality to include ATI farmer data in the payload -->
    <!-- and implements state-based publishing with approval confirmation wizard -->

    <!-- Add approval wizard action to partner form -->
    <record id="view_partner_form_websub_ati" model="ir.ui.view">
        <field name="name">res.partner.form.websub.ati</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Add WebSub approval button in header -->
            <xpath expr="//header" position="inside">
                <button name="state_approve"
                        string="🚀 Approve with WebSub Check"
                        type="object"
                        class="btn-success"
                        invisible="state == 'approved' or not is_registrant"
                        help="Approve partner with WebSub/Kafka connectivity check"/>
            </xpath>
        </field>
    </record>
</odoo>
