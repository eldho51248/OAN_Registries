<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Partner Approval Wizard Form View -->
    <record id="view_partner_approval_wizard_form" model="ir.ui.view">
        <field name="name">partner.approval.wizard.form</field>
        <field name="model">partner.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Partner Approval Confirmation">
                <div class="alert alert-info" role="alert">
                    <h4>⚠️ Partner Approval Confirmation</h4>
                    <p>You are about to approve the selected partner(s). Please review the WebSub and Kafka service status below.</p>
                </div>
                
                <group>
                    <group string="Service Status">
                        <field name="websub_status" readonly="1"/>
                        <field name="kafka_status" readonly="1"/>
                    </group>
                </group>
                
                <div class="alert alert-warning" role="alert" style="white-space: pre-line;">
                    <field name="warning_message" readonly="1" nolabel="1"/>
                </div>
                
                <group string="Partners to Approve">
                    <field name="partner_ids" readonly="1" nolabel="1">
                        <tree>
                            <field name="name"/>
                            <field name="state"/>
                            <field name="is_registrant"/>
                        </tree>
                    </field>
                </group>
                
                <footer>
                    <button name="action_approve_with_publishing" 
                            string="✅ Approve &amp; Publish to WebSub" 
                            type="object" 
                            class="btn-primary"/>
                    <button name="action_approve_without_publishing" 
                            string="⚠️ Approve WITHOUT Publishing" 
                            type="object" 
                            class="btn-warning"/>
                    <button name="action_cancel" 
                            string="❌ Cancel" 
                            type="object" 
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Partner Approval Wizard Action -->
    <record id="action_partner_approval_wizard" model="ir.actions.act_window">
        <field name="name">Approve Partners</field>
        <field name="res_model">partner.approval.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_view_types">form,list</field>
    </record>
</odoo>
