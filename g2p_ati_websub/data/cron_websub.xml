<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="param_websub_batch_size" model="ir.config_parameter">
            <field name="key">g2p.websub.batch_size</field>
            <field name="value">200</field>
        </record>      

        <record id="param_websub_disable" model="ir.config_parameter">
            <field name="key">g2p.websub.disable_websub</field>
            <field name="value">true</field>
        </record>
    </data>

    <data noupdate="0">
        <record id="cron_websub_publish" model="ir.cron">
            <field name="name">WebSub: Publish Data</field>
            <field name="model_id" ref="model_g2p_datashare_config_websub"/>
            <field name="state">code</field>
            <field name="code">model.cron_run_websub_publish()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">hours</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>