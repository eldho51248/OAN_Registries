<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_g2p_consent_data_field_tree" model="ir.ui.view">
        <field name="name">g2p.consent.data.field.tree</field>
        <field name="model">g2p.consent.data.field</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
                <field name="code" />
                <field name="payload_key" />
                <field name="source_path" />
                <field name="active" />
            </tree>
        </field>
    </record>

    <record id="view_g2p_consent_data_field_form" model="ir.ui.view">
        <field name="name">g2p.consent.data.field.form</field>
        <field name="model">g2p.consent.data.field</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group col="2">
                        <group>
                            <field name="name" />
                            <field name="code" />
                        </group>
                        <group>
                            <field name="payload_key" />
                            <field name="active" />
                        </group>
                    </group>
                    <group>
                        <field
                            name="source_path"
                            placeholder="e.g. name or region.name or land_information_ids.total_land_area"
                        />
                    </group>
                    <separator string="Advanced Mapping" />
                    <field name="mapping_line_ids" nolabel="1" colspan="4">
                        <tree editable="bottom">
                            <field name="sequence" />
                            <field name="payload_key" />
                            <field name="source_path" />
                        </tree>
                        <form string="Advanced Mapping Line">
                            <group>
                                <field name="sequence" />
                                <field name="payload_key" />
                                <field name="source_path" />
                            </group>
                        </form>
                    </field>
                    <group>
                        <field name="description" colspan="4" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_g2p_consent_data_field" model="ir.actions.act_window">
        <field name="name">Consent Data Fields</field>
        <field name="res_model">g2p.consent.data.field</field>
        <field name="view_mode">tree,form</field>
    </record>

    <menuitem
        id="menu_g2p_consent_configuration_root"
        name="Configuration"
        parent="g2p_ati_consent_mgt.menu_g2p_ati_consent_management_root"
        sequence="30"
    />

    <menuitem
        id="menu_g2p_consent_data_fields"
        name="Data Fields"
        parent="menu_g2p_consent_configuration_root"
        action="action_g2p_consent_data_field"
        sequence="20"
    />
</odoo>
