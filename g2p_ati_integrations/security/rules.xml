<odoo>

<record model="ir.module.category" id="g2p_draft_publish.integration_module">
    <field name="name">ATI Integrations</field>
</record>


<record id="rule_imported_record_followers" model="ir.rule">
    <field name="name">Imported Records - Followers Only</field>
    <field name="model_id" ref="g2p_ati_integrations.model_g2p_imported_record"/>
    <field name="groups" eval="[(4, ref('base.group_user'))]"/>  <!-- Adjust if needed -->
    <field name="domain_force">[
        '|', ('create_uid', '=', user.id),
        ('message_follower_ids.partner_id', '=', user.partner_id.id)
    ]</field>
</record>

<record id="g2p_draft_record_following_restriction_rule" model="ir.rule">
    <field name="name">Draft Records - Creator Only</field>
    <field name="model_id" ref="g2p_draft_publish.model_draft_record"/>
    <field name="groups" eval="[(4, ref('base.group_user'))]"/> <!-- All users -->
    <field name="domain_force">[('create_uid', '=', user.id)]</field>
</record>


