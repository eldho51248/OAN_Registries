    <record id="action_draft_imported_farmer_record" model="ir.actions.act_window">
        <field name="name">Draft</field>
        <field name="res_model">draft.imported.record</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('state', '!=', 'submitted')]</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0,0,{'view_mode': 'kanban', 'view_id': ref('g2p_draft_publish.view_draft_imported_kanban')}),
                (0,0,{'view_mode': 'tree', 'view_id': ref('view_draft_imported_farmer_record_tree')}),
                (0,0,{'view_mode': 'form', 'view_id': ref('g2p_draft_publish.view_draft_imported_record_form')})]" />
    </record>

    <record id="action_submitted_draft_imported_farmer_record" model="ir.actions.act_window">
        <field name="name">Submitted</field>
        <field name="res_model">draft.imported.record</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">['|',('state', '=', 'submitted'),('state', '=', 'published')]</field>
        <field name="view_ids" eval="[(5, 0, 0),
                (0,0,{'view_mode': 'tree', 'view_id': ref('view_draft_imported_farmer_record_tree')}),
                (0,0,{'view_mode': 'form', 'view_id': ref('g2p_draft_publish.view_draft_imported_record_form')})]" />
        <field name="context">{'create': False}</field>
    </record>


<menuitem id="g2p_draft_publish.menu_g2p_integration_root" name="Integrations"  web_icon="g2p_ati_integrations,static/description/icon.png"/>


