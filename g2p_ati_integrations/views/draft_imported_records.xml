<odoo>
    <record id="view_draft_imported_farmer_record_tree" model="ir.ui.view">
        <field name="name">draft.imported.record.tree</field>
        <field name="model">draft.imported.record</field>
         <field name="inherit_id" ref="g2p_draft_publish.view_draft_imported_record_tree"/>

        <field name="arch" type="xml">

        <xpath expr="//field[@name='addl_name']" position="attributes">
             <attribute name="column_invisible">1</attribute>
        </xpath>

        <xpath expr="//field[@name='family_name']" position="after">
          <field name="gf_name_eng"/>
        </xpath>


         <xpath expr="//field[@name='region']" position="after">
                <field name="zone"/>
                <field name="woreda"/>
                <field name="kebele"/>
            </xpath>



        </field>
    </record>



  



    <record id="g2p_validation_farmer_form_view" model="ir.ui.view">
        <field name="name">Validation Farmer Form View</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_ati.g2p_registry_farmer_form_view_inherit_no_create"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//header" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>



            <xpath expr="//notebook" position="after">
                <footer>

                    <!-- <button class="btn btn-info" name="action_save_to_draft" string="Save" type="object"/> -->

                    <button class="btn btn-info" name="action_update" string="Save" type="object"/>
                    <button string="Discard" class="btn btn-warning" special="cancel" data-hotkey="x"/>
                    <button class="btn btn-success" name="action_submit" string="Submit" type="object"/>
                    <button class="btn btn-success" name="action_publish" string="Publish" type="object" groups="g2p_draft_publish.group_int_approver,g2p_draft_publish.group_int_admin"/>
                </footer>
            </xpath>
        </field>
    </record>

