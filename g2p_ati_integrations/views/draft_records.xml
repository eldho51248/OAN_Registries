<odoo>
     <record id="view_draft_imported_kanban" model="ir.ui.view">
        <field name="name">draft.record</field>
        <field name="model">draft.record</field>
        <field name="arch" type="xml">
        
            <kanban
                default_group_by="validation_status"
                string="Enrichment Status"
                class="o_kanban_small_column o_kanban_project_tasks"
                quick_create="false" create="false" 
                quick_create_view="view_g2p_validation_status_form"
                editable="top"
                records_draggable="0"
            >
            <field name="name" />
            <templates>
                <t t-name="kanban-box">
                    <t t-set="kanban_record" t-value="record" />
                    <div t-attf-class="my-2 o_kanban_card shadow-sm border rounded p-3">
                        <!-- Card Header -->
                        <div class="o_kanban_details mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <strong class="text-primary">
                                    <field name="name" />
                                </strong>
                                <div>
                                        <field widget="badge" name="state" class="badge" />


                                </div>


                               
                            </div>
                        </div>

                        <separator/>


                        <div class="mt-2">
                            <div class="d-flex flex-wrap gap-2 justify-content-between">
                               
                                <t t-if="record.state.raw_value != 'published'">
                                    <button
                                            string="Change State"
                                            type="object"
                                            name="action_change_state"
                                            groups="g2p_draft_publish.group_int_validator,g2p_draft_publish.group_int_admin"
                                            class="btn btn-secondary btn-sm"
                                        />
                                </t>


                                <t t-if="record.state.raw_value == 'draft'">
                                    <button
                                            string="Edit"
                                            type="object"
                                            name="action_open_wizard"
                                            groups="g2p_draft_publish.group_int_validator,g2p_draft_publish.group_int_admin"
                                            class="btn btn-primary btn-sm"
                                        />
                                    <button
                                            string="Submit"
                                            type="object"
                                            name="action_submit"
                                            groups="g2p_draft_publish.group_int_validator,g2p_draft_publish.group_int_admin"
                                            class="btn btn-success btn-sm"
                                        />
                                </t>

                                <t t-if="record.state.raw_value == 'submitted'">

                                <button
                                            string="Publish"
                                            type="object"
                                            name="action_publish"
                                            groups="g2p_draft_publish.group_int_approver,g2p_draft_publish.group_int_admin"
                                            class="btn btn-success btn-sm"
                                        />
                                <button
                                            string="Reject"
                                            invisible="state!='submitted'"
                                            type="object"
                                            name="action_reject"
                                            groups="g2p_draft_publish.group_int_approver,g2p_draft_publish.group_int_admin"
                                            class="btn btn-danger btn-sm"
                                        />
                                </t>

                            </div>
                        </div>

                        
                        <t t-if="record.rejection_reason.raw_value">
                            <div class="mt-3 mb-3">
                                <strong class="text-muted">Remark: </strong>
                                <field name="rejection_reason" />
                            </div>
                            </t>
                   

                    </div>
                </t>
            </templates>

        </kanban>
        </field>
    </record>


    <record id="view_partner_form_inherited" model="ir.ui.view">
        <field name="name">res.partner.form.inherited.lang</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form" />
        <field name="arch" type="xml">
             <xpath expr="//field[@name='lang']" position="after">
                <field name="asigned_region" />
                <field name="language_skills" widget="many2many_tags" />
             </xpath>
        </field>
    </record>



    <record id="view_draft_imported_farmer_record_tree" model="ir.ui.view">
        <field name="name">draft.record.tree</field>
        <field name="model">draft.record</field>
        <field name="inherit_id" ref="g2p_draft_publish.view_draft_imported_record_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='addl_name']" position="attributes">
                <attribute name="column_invisible">1</attribute>
            </xpath>
            
            <xpath expr="//field[@name='family_name']" position="after">
                <field name="gf_name_eng" 
                readonly="id!=False"
                 />
            </xpath>
            <xpath expr="//field[@name='region']" position="after">
                <field name="zone" />
                <field name="woreda" />
                <field name="kebele" />
            </xpath>
        </field>
    </record>




    <record id="draft_record_followers_rule" model="ir.rule">
    <field name="name">Draft Record: Only Followers</field>
    <field name="model_id" ref="model_draft_record" />
    <field name="global" eval="False" />
    <field name="domain_force">[('create_uid', '=', user.id)]</field>
</record>

    <record id="view_draft_imported_farmer_record_lmap" model="ir.ui.view">
        <field name="name">draft.record.map</field>
        <field name="model">draft.record</field>
        <field name="arch" type="xml">
            <lmap />
        </field>
    </record>

    <record id="res_partner_hide_publish_reject_buttons" model="ir.ui.view">
        <field name="name">res.partner.form.hide.buttons</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_draft_publish.g2p_validation_form_view" />
        <field name="arch" type="xml">

            <xpath expr="//header" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>


        </field>
    </record> 

    <record id="g2p_validation_base_tree_view_db_import_label" model="ir.ui.view">
        <field name="name">g2p.validation.base.tree.db.import.label</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_draft_publish.g2p_validation_base_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='db_import']" position="attributes">
                <attribute name="string">DB import</attribute>
            </xpath>
        </field>
    </record>


    <record id="action_draft_imported_farmer_record" model="ir.actions.act_window">
        <field name="name">Draft</field>
        <field name="res_model">draft.record</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('state', 'not in', ['submitted', 'published'])]</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0,0,{'view_mode': 'kanban', 'view_id': ref('g2p_ati_integrations.view_draft_imported_kanban')}),
                (0,0,{'view_mode': 'tree', 'view_id': ref('view_draft_imported_farmer_record_tree')}),
                (0,0,{'view_mode': 'form', 'view_id': ref('g2p_draft_publish.view_draft_imported_record_form')})]"
        />
    </record>

    <record id="action_ati_cleaned_record" model="ir.actions.act_window">
        <field name="name">Cleaned</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0,0,{'view_mode': 'tree', 'view_id': ref('g2p_registry_individual.view_individuals_list_tree')}),
                (0,0,{'view_mode': 'form', 'view_id': ref('g2p_registry_individual.view_individuals_form')})]"
        />
        <field name="domain">[('db_import', '=', 'yes')]</field>
        <field name="context">{'create': False}</field>
    </record>


    <record id="action_draft_imported_record" model="ir.actions.act_window">
        <field name="name">Draft</field>
        <field name="res_model">draft.record</field>
        <field name="view_mode">kanban,tree,form,lmap</field>
        <field name="domain">[('state', '!=', 'submitted')]</field>
        <field
            name="view_ids"
            eval="[(5, 0, 0),
                (0,0,{'view_mode': 'kanban', 'view_id': ref('view_draft_imported_kanban')}),
                (0,0,{'view_mode': 'tree', 'view_id': ref('view_draft_imported_farmer_record_tree')}),
                (0,0,{'view_mode': 'form', 'view_id': ref('g2p_draft_publish.view_draft_imported_record_form')})]"
        />
    </record>

    <record id="g2p_draft_publish.menu_draft_imported_farmer_record" model="ir.ui.menu">
        <field name="name">Drafts</field>
        <field name="action" ref="action_draft_imported_farmer_record" />
    </record>


    <menuitem
        id="menu_g2p_integration_configurations"
        name="Configurations"
        parent="g2p_draft_publish.draft_publish_main_menu"
        sequence="100"
    />
    <menuitem
        id="menu_g2p_validation_status"
        name="Enrichment Status"
        parent="menu_g2p_integration_configurations"
        action="g2p_ati_integrations.action_g2p_validation_status"
    />

    <menuitem
        id="g2p_draft_publish.menu_ati_cleand_records_root"
        name="Cleaned Records"
        action="action_ati_cleaned_record"
        groups="g2p_draft_publish.group_int_admin,g2p_draft_publish.group_int_approver"
        web_icon="g2p_ati_integrations,static/description/checkmark.png"
    />



    <record id="g2p_ati.menu_action_crop_info" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('g2p_draft_publish.group_int_admin')),(4, ref('g2p_draft_publish.group_int_approver'))]"/>
    </record>

    <record id="g2p_ati.menu_action_livestock" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('g2p_draft_publish.group_int_admin')),(4, ref('g2p_draft_publish.group_int_approver'))]"/>
    </record>

    <record id="g2p_ati.menu_action_land_info" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('g2p_draft_publish.group_int_admin')),(4, ref('g2p_draft_publish.group_int_approver'))]"/>
    </record>

    <record id="g2p_ati.menu_action_household" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('g2p_draft_publish.group_int_admin')),(4, ref('g2p_draft_publish.group_int_approver'))]"/>
    </record>

    <record id="g2p_ati.menu_action_individual" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('g2p_draft_publish.group_int_admin')),(4, ref('g2p_draft_publish.group_int_approver'))]"/>
    </record>

    <record id="g2p_ati.menu_action_farmer" model="ir.ui.menu">
        <field name="groups_id" eval="[(4, ref('g2p_draft_publish.group_int_admin')),(4, ref('g2p_draft_publish.group_int_approver'))]"/>
    </record>




</odoo>
