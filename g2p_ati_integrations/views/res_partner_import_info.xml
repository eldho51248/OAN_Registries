<odoo>
    <record id="res_partner_import_information_integration" model="ir.ui.view">
        <field name="name">res.partner.import.information.integration</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="g2p_registry_individual.view_individuals_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='other']" position="inside">
                <group string="Import Information">
                    <field name="source_db_ids" widget="many2many_tags" options="{'color_field': 'color'}" />
                </group>
            </xpath>
        </field>
    </record>
</odoo>
