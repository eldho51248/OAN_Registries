<odoo>
    <!-- Tree View -->
    <record id="view_imported_farmer_record_tree" model="ir.ui.view">
        <field name="name">g2p.imported.farmer.record.tree</field>
        <field name="model">g2p.imported.record</field>
        <field name="inherit_id" ref="g2p_draft_publish.view_imported_record_tree"/>
        <field name="arch" type="xml">

           <xpath expr="//field[@name='region']" position="after">
                <field name="zone"/>
                <field name="woreda"/>
                <field name="kebele"/>
            </xpath>
        </field>
    </record>



    
    <record id="view_imported_farmer_record_form" model="ir.ui.view">
        <field name="name">g2p.imported.farmer.record.form</field>
        <field name="model">g2p.imported.record</field>
        <field name="inherit_id" ref="g2p_draft_publish.view_imported_record_form"/>

        <field name="arch" type="xml">

             <xpath expr="//field[@name='region']" position="attributes">
                 <attribute name="invisible">1</attribute>
             </xpath>


         


           <xpath expr="//field[@name='gender']" position="after">
                            <field name="region" />
                            <field name="zone"  />
                            <field name="woreda" />
                            <field name="kebele" />

            </xpath>

        </field>
    </record>









