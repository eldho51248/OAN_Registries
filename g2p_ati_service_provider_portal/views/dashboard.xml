<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template
        id="ati_dashboard_template"
        inherit_id="g2p_service_provider_portal_base.home_page"
        customize_show="True"
        name="ATI Dashboard"
        priority="200"
    >
        <xpath expr="//div[hasclass('container-adjuster')]" position="replace">
          <div class="container-adjuster custom-dashboard-background" style="display: flex; justify-content: center; align-items: center;">
>
<div class="d-flex flex-column flex-md-row gap-5 my-5 py-5">
    
    <!-- <a href="/serviceprovider/individual">
    </a> -->

    <div class="gradient-card py-5" style="box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);">
        <a href="/serviceprovider/individual">
            <h5 class="card-heading" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/h5[1]">Farmers</h5>
            <img  src="/g2p_ati_service_provider_portal/static/src/img/dashboard.png" class="img mx-auto" style="width: 70px; height: 70px; margin-top: 8%; margin-bottom: 3%;" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/img[1]" loading="lazy"/>
            <center>
                <strong style="font-size:16px;color: #09A261; margin-top: 5%;">
                                    7
                                    Farmers
                </strong>
            </center>
            <div style="display: flex; justify-content: center; align-items: center; padding-left: 5%; padding-right: 5%;">
                <p style="font-size:12px;text-align: center; display: -webkit-box; -webkit-box-orient: vertical;overflow: hidden;">
                                        More than
                                        7
                                        Farmers created.
                </p>
            </div>
            <hr style="width: 70%; margin-left: 15%; margin-top: 7%;" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/hr[1]"/>
        </a>
        <div class="card-foot" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/div[2]">
            <a href="/serviceprovider/individual">
            </a>
            <a href="/serviceprovider/individual" class="justify-content-center viewprograms group" style="color: #09A261;font-size:16px;">
                                        View Farmer List
                <img src="/g2p_ati_service_provider_portal/static/src/img/arrow.jpeg" class="img" style="width: 14px; height: 14px;" loading="lazy"/>
            </a>
        </div>
    </div>

    <div class="gradient-card py-5" style="box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);">
        <a href="/serviceprovider/group">
            <h5 class="card-heading" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/h5[1]">Households</h5>
            <img src="/g2p_ati_service_provider_portal/static/src/img/dashboard.png" class="img mx-auto" style="width: 70px; height: 70px; margin-top: 8%; margin-bottom: 3%;" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/img[1]" loading="lazy"/>
            <center>
                <strong style="font-size:16px;color: #09A261; margin-top: 5%;">
                                    7
                                    Households
                </strong>
            </center>
            <div style="display: flex; justify-content: center; align-items: center; padding-left: 5%; padding-right: 5%;">
                <p style="font-size:12px;text-align: center; display: -webkit-box; -webkit-box-orient: vertical;overflow: hidden;">
                                        More than
                                        7
                                        Households created.
                </p>
            </div>
            <hr style="width: 70%; margin-left: 15%; margin-top: 7%;" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/hr[1]"/>
        </a>
        <div class="card-foot" data-oe-model="ir.ui.view" data-oe-id="1666" data-oe-field="arch" data-oe-xpath="/data/xpath[1]/div/div[1]/div[1]/a[1]/div[1]/div[2]">
            <a href="/serviceprovider/individual">
            </a>
            <a href="/serviceprovider/group" class="justify-content-center viewprograms group" style="color: #09A261;font-size:16px;">
                                        View Household List
                <img src="/g2p_ati_service_provider_portal/static/src/img/arrow.jpeg" class="img" style="width: 14px; height: 14px;" loading="lazy"/>
            </a>
        </div>
    </div>


